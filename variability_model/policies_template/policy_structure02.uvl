namespace Policies
imports
    k8s.Kubernetes as Kubernetes
features
	PoliciesKyverno {abstract}
		optional
			Pod_Security_Standards_Baseline
				optional
					Disallow_Host_Namespaces {doc 'Impide que un Pod comparta los namespaces del host', severity 'medium', action 'audit', k8sRange '1_22‑1_23'}
					Disallow_hostPath
					Disallow_hostPorts_Range_Alternate					
constraints
	Disallow_Host_Namespaces => (!Kubernetes.io_k8s_api_core_v1_Pod_spec_hostPID & !Kubernetes.io_k8s_api_core_v1_Pod_spec_hostIPC & !Kubernetes.io_k8s_api_core_v1_Pod_spec_hostNetwork)
	Disallow_hostPath => !Kubernetes.io_k8s_api_core_v1_Pod_spec_volumes_hostPath
	Disallow_hostPorts_Range_Alternate => (((Kubernetes.io_k8s_api_core_v1_Pod_spec_ephemeralContainers_ports_hostPort > 4999 & Kubernetes.io_k8s_api_core_v1_Pod_spec_ephemeralContainers_ports_hostPort < 6001) | Kubernetes.io_k8s_api_core_v1_Pod_spec_ephemeralContainers_ports_hostPort = 0) & ((Kubernetes.io_k8s_api_core_v1_Pod_spec_initContainers_ports_hostPort > 4999 & Kubernetes.io_k8s_api_core_v1_Pod_spec_initContainers_ports_hostPort < 6001) | Kubernetes.io_k8s_api_core_v1_Pod_spec_initContainers_ports_hostPort = 0) & ((Kubernetes.io_k8s_api_core_v1_Pod_spec_containers_ports_hostPort > 4999 & Kubernetes.io_k8s_api_core_v1_Pod_spec_containers_ports_hostPort < 6001) | Kubernetes.io_k8s_api_core_v1_Pod_spec_containers_ports_hostPort = 0))