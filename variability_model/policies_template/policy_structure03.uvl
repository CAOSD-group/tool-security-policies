namespace Policies
features
	PoliciesKyverno {abstract}
		optional
			Pod_Security_Standards_Baseline
				optional
					Disallow_Host_Namespaces {doc 'Impide que un Pod comparta los namespaces del host', severity 'medium', action 'audit', k8sRange '1_22‑1_23'}
						optional
							Pod_spec_hostPID
							Pod_spec_hostIPC
							Pod_spec_hostNetwork
					Disallow_hostPath
						optional
							Pod_spec_volumes_hostPath
					Disallow_hostPorts_Range_Alternate
						optional
							Integer Pod_spec_ephemeralContainers_ports_hostPort
							Integer Pod_spec_initContainers_ports_hostPort
							Integer Pod_spec_containers_ports_hostPort												
constraints
	Disallow_Host_Namespaces => (!Pod_spec_hostPID & !Pod_spec_hostIPC & !Pod_spec_hostNetwork)
	Disallow_hostPath => !Pod_spec_volumes_hostPath
	Disallow_hostPorts_Range_Alternate => (((Pod_spec_ephemeralContainers_ports_hostPort > 4999 & Pod_spec_ephemeralContainers_ports_hostPort < 6001) | Pod_spec_ephemeralContainers_ports_hostPort = 0) & ((Pod_spec_initContainers_ports_hostPort > 4999 & Pod_spec_initContainers_ports_hostPort < 6001) | Pod_spec_initContainers_ports_hostPort = 0) & ((Pod_spec_containers_ports_hostPort > 4999 & Pod_spec_containers_ports_hostPort < 6001) | Pod_spec_containers_ports_hostPort = 0))
