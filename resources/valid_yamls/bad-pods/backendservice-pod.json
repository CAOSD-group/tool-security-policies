{
    "filename": "backendservice-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "backendservice-pod",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "backend",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "student-service"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "backendservice-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "ramit07/springboot_studentservice_multiarch",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 8090
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "db_url",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "jdbc:postgresql://postgres-db:5432/student_service_db"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "db_username",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "postgres"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "db_password",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "zxcv"
                        }
                    ]
                }
            ]
        }
    }
}