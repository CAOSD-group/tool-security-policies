{
    "filename": "3.9.2 pod-with-2-init.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "pod-with-2-init",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "nginx"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_initContainers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_initContainers_name": "init-myservice",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_image": "busybox",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_IfNotPresent": true,
                        "io_k8s_api_core_v1_Pod_spec_initContainers_imagePullPolicy_IfNotPresent": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_initContainers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "until nslookup myservice.$(cat /var/run/secrets/kubernetes.io/serviceaccount/namespace).svc.cluster.local; do echo waiting for myservice; sleep 2; done"
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_initContainers_name": "init-mydb",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_image": "busybox",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_IfNotPresent": true,
                        "io_k8s_api_core_v1_Pod_spec_initContainers_imagePullPolicy_IfNotPresent": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_initContainers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "until nslookup mydb.$(cat /var/run/secrets/kubernetes.io/serviceaccount/namespace).svc.cluster.local; do echo waiting for mydb; sleep 2; done"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "myapp-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "busybox",
                    "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_IfNotPresent": true,
                        "io_k8s_api_core_v1_Pod_spec_initContainers_imagePullPolicy_IfNotPresent": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "echo The app is running! && sleep 3600"
                        }
                    ]
                }
            ]
        }
    }
}