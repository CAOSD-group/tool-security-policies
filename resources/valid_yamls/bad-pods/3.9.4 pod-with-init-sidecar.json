                                },
                                {
                                    "io_k8s_api_core_v1_Pod_spec_initContainers_readinessProbe_exec_command_StringValue": "-c"
                                },
                                {
                                    "io_k8s_api_core_v1_Pod_spec_initContainers_readinessProbe_exec_command_StringValue": "ls /opt/logs.txt"
