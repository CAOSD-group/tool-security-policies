{
    "filename": "3.6.1 dapi-envars-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "dapi-envars-fieldref"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "test-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "busybox",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "-c"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "while true; do echo -en '\\n'; printenv MY_NODE_NAME MY_POD_NAME MY_POD_NAMESPACE; printenv MY_POD_IP MY_POD_SERVICE_ACCOUNT; sleep 10; done;"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MY_NODE_NAME",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef_fieldPath": "spec.nodeName"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MY_POD_NAME",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef_fieldPath": "metadata.name"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MY_POD_NAMESPACE",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef_fieldPath": "metadata.namespace"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MY_POD_IP",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef_fieldPath": "status.podIP"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MY_POD_SERVICE_ACCOUNT",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_fieldRef_fieldPath": "spec.serviceAccountName"
                                }
                            }
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_restartPolicy": {
                "io_k8s_api_core_v1_Pod_spec_restartPolicy_Never": true
            }
        }
    }
}