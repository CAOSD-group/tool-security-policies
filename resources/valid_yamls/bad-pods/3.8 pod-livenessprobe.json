{
    "filename": "3.8 pod-livenessprobe.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "test",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "liveness"
                }
            ],
            "io_k8s_api_core_v1_Pod_metadata_name": "liveness-exec"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "liveness",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "gcr.io/google_containers/busybox",
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "/bin/sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "echo ok > /tmp/health; sleep 10; rm -rf /tmp/health; sleep 600"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_exec": {
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_exec_command": [
                                {
                                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_exec_command_StringValue": "cat"
                                },
                                {
                                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_exec_command_StringValue": "/tmp/health"
                                }
                            ]
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_initialDelaySeconds": 15,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_timeoutSeconds": 1
                    }
                }
            ]
        }
    }
}