{
    "filename": "app-pod-pv.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "nginx-pod",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "name",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "myapp"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "env",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "dev"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "nginx-pv-storage",
                    "io_k8s_api_core_v1_Pod_spec_volumes_persistentVolumeClaim": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_persistentVolumeClaim_claimName": "nginx-pvc"
                    }
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx-1",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "nginx-pv-storage",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/app/data"
                        }
                    ]
                }
            ]
        }
    }
}