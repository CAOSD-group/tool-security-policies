{
    "filename": "backend-pod2.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_annotations": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_annotations_KeyMap": "kompose.cmd",
                    "io_k8s_api_core_v1_Pod_metadata_annotations_ValueMap": "kompose convert"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_annotations_KeyMap": "kompose.version",
                    "io_k8s_api_core_v1_Pod_metadata_annotations_ValueMap": "1.32.0 (765fde254)"
                }
            ],
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "io.kompose.network/chat-socket-challenge-main-angular-chat-net",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "true"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "io.kompose.service",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "backend"
                }
            ],
            "io_k8s_api_core_v1_Pod_metadata_name": "backend"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MONGO_HOST",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "mongo"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MONGO_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "devpassword"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MONGO_PORT",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "27017"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MONGO_USERNAME",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "devuser"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "SPRING_PROFILES_ACTIVE",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "pdn"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "gporras/chat-socket-broker:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_exec": {
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_exec_command": [
                                {
                                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_exec_command_StringValue": "curl -m 5 --silent --fail --request GET http://localhost:8080/actuator/health | jq --exit-status -n 'inputs | if has(\"status\") then .status==\"UP\" else false end' > /dev/null || exit 1"
                                }
                            ]
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_failureThreshold": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_periodSeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_timeoutSeconds": 2
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "backend",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 8080,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_hostPort": 8080,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol": {
                                "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol_TCP": true
                            }
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_restartPolicy": {
                "io_k8s_api_core_v1_Pod_spec_restartPolicy_OnFailure": true
            }
        }
    }
}