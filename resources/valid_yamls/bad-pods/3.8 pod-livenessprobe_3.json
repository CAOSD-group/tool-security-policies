{
    "filename": "3.8 pod-livenessprobe_3.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "etcd-with-grpc"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "etcd",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "etcd:3.5.1",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "/usr/local/bin/etcd"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "--data-dir"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "/var/lib/etcd"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "--listen-client-urls"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "http://0.0.0.0:2379"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "--advertise-client-urls"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "http://127.0.0.1:2379"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 2379
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_grpc": {
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_grpc_port": 2379
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_initialDelaySeconds": 10
                    }
                }
            ]
        }
    }
}