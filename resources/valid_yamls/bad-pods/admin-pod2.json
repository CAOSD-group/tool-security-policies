                    "io_k8s_api_core_v1_Pod_spec_containers_name": "rethinkdb",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "POD_NAMESPACE",
