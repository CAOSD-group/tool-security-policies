            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "db",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "rethinkdb"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "role",
