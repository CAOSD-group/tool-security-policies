                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 3306,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_name": "cport-3306"
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "pidev-backend",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "mdjdocker/arctic4_pidev_backend:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 9000,
