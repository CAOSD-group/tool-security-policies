{
    "filename": "automagic-nginx-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "automagic-nginx-pod",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "automagic-developer",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "name",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "automagic-nginx-pod"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "environment",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "production"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "service-type",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "frontend"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "automagic-developer"
                }
            ],
            "io_k8s_api_core_v1_Pod_metadata_annotations": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_annotations_KeyMap": "imageregistry",
                    "io_k8s_api_core_v1_Pod_metadata_annotations_ValueMap": "https://hub.docker.com/"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_securityContext": {
                "io_k8s_api_core_v1_Pod_spec_securityContext_runAsUser": 1000,
                "io_k8s_api_core_v1_Pod_spec_securityContext_runAsGroup": 1000,
                "io_k8s_api_core_v1_Pod_spec_securityContext_fsGroup": 1000
            },
            "io_k8s_api_core_v1_Pod_spec_imagePullSecrets": [
                {
                    "io_k8s_api_core_v1_Pod_spec_imagePullSecrets_name": "dockerhub-secret"
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_restartPolicy": {
                "io_k8s_api_core_v1_Pod_spec_restartPolicy_Always": true
            },
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "mabdelgawad94/automagic_developer:automagic-nginx-server",
                    "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_Always": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 8080
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/website/media/",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "automagic-app-media-pvc"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_tcpSocket": {
                            "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_tcpSocket_port": {
                                "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_tcpSocket_port_asInteger": 8080
                            }
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_initialDelaySeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_periodSeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_failureThreshold": 20
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_tcpSocket": {
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_tcpSocket_port": {
                                "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_tcpSocket_port_asInteger": 8080
                            }
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_initialDelaySeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_periodSeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_failureThreshold": 20
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_requests": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "memory:10M"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asNumber": "cpu:0.01"
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:2G"
                            }
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext": {
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_allowPrivilegeEscalation": false
                    }
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "automagic-app-media-pvc",
                    "io_k8s_api_core_v1_Pod_spec_volumes_persistentVolumeClaim": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_persistentVolumeClaim_claimName": "automagic-app-media-pvc"
                    }
                }
            ]
        }
    }
}