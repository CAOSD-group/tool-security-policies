{
    "filename": "06-pod.config_1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Service_apiVersion": "v1",
        "io_k8s_api_core_v1_Service_kind": "Service",
        "io_k8s_api_core_v1_Service_metadata": {
            "io_k8s_api_core_v1_Service_metadata_name": "service-pod"
        },
        "io_k8s_api_core_v1_Service_spec": {
            "io_k8s_api_core_v1_Service_spec_selector": [
                {
                    "io_k8s_api_core_v1_Service_spec_selector_KeyMap": "production",
                    "io_k8s_api_core_v1_Service_spec_selector_ValueMap": "yes"
                },
                {
                    "io_k8s_api_core_v1_Service_spec_selector_KeyMap": "team",
                    "io_k8s_api_core_v1_Service_spec_selector_ValueMap": "testing"
                }
            ],
            "io_k8s_api_core_v1_Service_spec_ports": [
                {
                    "io_k8s_api_core_v1_Service_spec_ports_name": "service-port",
                    "io_k8s_api_core_v1_Service_spec_ports_port": 80,
                    "io_k8s_api_core_v1_Service_spec_ports_targetPort": {
                        "io_k8s_api_core_v1_Service_spec_ports_targetPort_asString": "http-web-srv"
                    }
                }
            ]
        }
    }
}