{
    "filename": "1.pod_frontend_3.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_networking_v1_Ingress_apiVersion": "networking.k8s.io/v1",
        "io_k8s_api_networking_v1_Ingress_kind": "Ingress",
        "io_k8s_api_networking_v1_Ingress_metadata": {
            "io_k8s_api_networking_v1_Ingress_metadata_name": "ns-todo-app-k8s-local",
            "io_k8s_api_networking_v1_Ingress_metadata_namespace": "ns-todo-app-k8s-local",
            "io_k8s_api_networking_v1_Ingress_metadata_annotations": [
                {
                    "io_k8s_api_networking_v1_Ingress_metadata_annotations_KeyMap": "nginx.ingress.kubernetes.io/rewrite-target",
                    "io_k8s_api_networking_v1_Ingress_metadata_annotations_ValueMap": "/$1"
                }
            ]
        },
        "io_k8s_api_networking_v1_Ingress_spec": {
            "io_k8s_api_networking_v1_Ingress_spec_rules": [
                {
                    "io_k8s_api_networking_v1_Ingress_spec_rules_host": "frontend.info",
                    "io_k8s_api_networking_v1_Ingress_spec_rules_http": {
                        "io_k8s_api_networking_v1_Ingress_spec_rules_http_paths": [
                            {
                                "io_k8s_api_networking_v1_Ingress_spec_rules_http_paths_path": "/",
                                "io_k8s_api_networking_v1_Ingress_spec_rules_http_paths_pathType": "Prefix",
                                "io_k8s_api_networking_v1_Ingress_spec_rules_http_paths_backend": {
                                    "io_k8s_api_networking_v1_Ingress_spec_rules_http_paths_backend_service": {
                                        "io_k8s_api_networking_v1_Ingress_spec_rules_http_paths_backend_service_name": "frontend-service",
                                        "io_k8s_api_networking_v1_Ingress_spec_rules_http_paths_backend_service_port": {
                                            "io_k8s_api_networking_v1_Ingress_spec_rules_http_paths_backend_service_port_number": 8080
                                        }
                                    }
                                }
                            }
                        ]
                    }
                }
            ]
        }
    }
}