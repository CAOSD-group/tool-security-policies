{
    "filename": "06-pod.config.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "sample-nginx-configmap",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "roboshop",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "production",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "yes"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "team",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "testing"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx:alpine",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_name": "http-web-srv"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_requests": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "cpu:100m"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "memory:256Mi"
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:200m"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:512Mi"
                            }
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "database",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_name": "cource-config",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_key": "databasu_url"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "ipaddress",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_name": "cource-config",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_key": "api-server-ip"
                                }
                            }
                        }
                    ]
                }
            ]
        }
    }
}