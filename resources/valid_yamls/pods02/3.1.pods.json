                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "app2"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "duowngtora",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "duowngtora-app2-nginx"
