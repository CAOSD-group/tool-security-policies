{
    "filename": "03-pod-initContainers1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "init-demo"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_IfNotPresent": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "workdir",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/usr/share/nginx/html"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_initContainers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_initContainers_name": "install",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_image": "alpine",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "wget"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "-O"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "/work-dir/index.html"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "https://github.com/dubareddy/testcode/blob/master/index.html?raw=true"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_initContainers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_volumeMounts_name": "workdir",
                            "io_k8s_api_core_v1_Pod_spec_initContainers_volumeMounts_mountPath": "/work-dir"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_dnsPolicy": {
                "io_k8s_api_core_v1_Pod_spec_dnsPolicy_Default": true
            },
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "workdir",
                    "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir_isEmpty": true
                    }
                }
            ]
        }
    }
}