{
    "filename": "01_pod1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "my-pod",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "k8s-demystified",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "my-app"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "my-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "ghcr.io/stefanprodan/podinfo:6.6.1",
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_requests": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "cpu:100m"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "memory:64Mi"
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:256Mi"
                            }
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_name": "http",
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 9898,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol": {
                                "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol_TCP": true
                            }
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "./podinfo"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "--level=debug"
                        }
                    ]
                }
            ]
        }
    }
}