{
    "filename": "02-pod-jon.yaml",
    "apiVersion": "apps_v1",
    "config": {
        "io_k8s_api_apps_v1_Deployment_apiVersion": "apps/v1",
        "io_k8s_api_apps_v1_Deployment_kind": "Deployment",
        "io_k8s_api_apps_v1_Deployment_metadata": {
            "io_k8s_api_apps_v1_Deployment_metadata_name": "jon-deployment"
        },
        "io_k8s_api_apps_v1_Deployment_spec": {
            "io_k8s_api_apps_v1_Deployment_spec_replicas": 5,
            "io_k8s_api_apps_v1_Deployment_spec_selector": {
                "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels": [
                    {
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_KeyMap": "repo",
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_ValueMap": "private"
                    }
                ]
            },
            "io_k8s_api_apps_v1_Deployment_spec_template": {
                "io_k8s_api_apps_v1_Deployment_spec_template_metadata": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_KeyMap": "repo",
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_ValueMap": "private"
                        }
                    ]
                },
                "io_k8s_api_apps_v1_Deployment_spec_template_spec": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_name": "jonpod",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_image": "jdimitrakopoulos1/labs",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources": {
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_limits": [
                                    {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_limits_asString": "memory:100Mi"
                                    },
                                    {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_limits_asString": "cpu:250m"
                                    }
                                ],
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_requests": [
                                    {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_requests_asString": "memory:50Mi"
                                    },
                                    {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_requests_asString": "cpu:100m"
                                    }
                                ]
                            },
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_command": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_command_StringValue": "tail"
                                }
                            ],
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_args": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_args_StringValue": "-f"
                                },
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_args_StringValue": "/dev/null"
                                }
                            ]
                        }
                    ],
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_restartPolicy": {
                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_restartPolicy_Always": true
                    }
                }
            }
        }
    }
}