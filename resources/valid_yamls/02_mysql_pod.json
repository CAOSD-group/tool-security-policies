{
    "filename": "02_mysql_pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "mysql-server",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "default"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "mysql",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "mysql:8",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MYSQL_ROOT_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_name": "my-database-secret",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_key": "password"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MYSQL_USER",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_name": "my-database-secret",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_key": "username"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MYSQL_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_name": "my-database-secret",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_key": "password"
                                }
                            }
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 3306
                        }
                    ]
                }
            ]
        }
    }
}