{
    "filename": "nginx-pod-with-ubuntu.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "my-nginx-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "my-nginx-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "docker.io/nginx:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol": {
                                "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol_TCP": true
                            }
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "ubuntu-sidecar-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "docker.io/alicek106/rr-test:curl",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "tail"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "-f"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "/dev/null"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_imagePullSecrets": [
                {
                    "io_k8s_api_core_v1_Pod_spec_imagePullSecrets_name": "regcred"
                }
            ]
        }
    }
}