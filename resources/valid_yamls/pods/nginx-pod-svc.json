{
    "filename": "nginx-pod-svc.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "run",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "nginx"
                }
            ],
            "io_k8s_api_core_v1_Pod_metadata_name": "nginx",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "default"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "docker.io/nginx:alpine",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol": {
                                "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol_TCP": true
                            }
                        }
                    ]
                }
            ]
        }
    }
}