{
    "filename": "nginx-phpfpm-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "nginx-phpfpm",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "nginx-phpfpm"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "shared-files",
                    "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir_isEmpty": true
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "nginx-config-volume",
                    "io_k8s_api_core_v1_Pod_spec_volumes_configMap": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_configMap_name": "nginx-config"
                    }
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "shared-files",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/www/html"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "nginx-config-volume",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/etc/nginx/nginx.conf",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_subPath": "nginx.conf"
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "php-fpm-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "php:7.3-fpm-alpine",
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "shared-files",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/www/html"
                        }
                    ]
                }
            ]
        }
    }
