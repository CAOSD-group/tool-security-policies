{
    "filename": "replicaset-nginx-pods.yaml",
    "apiVersion": "apps_v1",
    "config": {
        "io_k8s_api_apps_v1_ReplicaSet_apiVersion": "apps/v1",
        "io_k8s_api_apps_v1_ReplicaSet_kind": "ReplicaSet",
        "io_k8s_api_apps_v1_ReplicaSet_metadata": {
            "io_k8s_api_apps_v1_ReplicaSet_metadata_name": "replicaset-nginx"
        },
        "io_k8s_api_apps_v1_ReplicaSet_spec": {
            "io_k8s_api_apps_v1_ReplicaSet_spec_replicas": 3,
            "io_k8s_api_apps_v1_ReplicaSet_spec_selector": {
                "io_k8s_api_apps_v1_ReplicaSet_spec_selector_matchLabels": [
                    {
                        "io_k8s_api_apps_v1_ReplicaSet_spec_selector_matchLabels_KeyMap": "app",
                        "io_k8s_api_apps_v1_ReplicaSet_spec_selector_matchLabels_ValueMap": "my-nginx-pods-label"
                    }
                ]
            },
            "io_k8s_api_apps_v1_ReplicaSet_spec_template": {
                "io_k8s_api_apps_v1_ReplicaSet_spec_template_metadata": {
                    "io_k8s_api_apps_v1_ReplicaSet_spec_template_metadata_name": "my-nginx-pod",
                    "io_k8s_api_apps_v1_ReplicaSet_spec_template_metadata_labels": [
                        {
                            "io_k8s_api_apps_v1_ReplicaSet_spec_template_metadata_labels_KeyMap": "app",
                            "io_k8s_api_apps_v1_ReplicaSet_spec_template_metadata_labels_ValueMap": "my-nginx-pods-label"
                        }
                    ]
                },
                "io_k8s_api_apps_v1_ReplicaSet_spec_template_spec": {
                    "io_k8s_api_apps_v1_ReplicaSet_spec_template_spec_containers": [
                        {
                            "io_k8s_api_apps_v1_ReplicaSet_spec_template_spec_containers_name": "nginx",
                            "io_k8s_api_apps_v1_ReplicaSet_spec_template_spec_containers_image": "nginx:latest",
                            "io_k8s_api_apps_v1_ReplicaSet_spec_template_spec_containers_ports": [
                                {
                                    "io_k8s_api_apps_v1_ReplicaSet_spec_template_spec_containers_ports_containerPort": 80
                                }
                            ]
                        }
                    ]
                }
            }
        }
    }
}