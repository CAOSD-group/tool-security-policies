{
    "filename": "pod-nginx11.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "my-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "config-volume",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/etc/config"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "config-volume",
                    "io_k8s_api_core_v1_Pod_spec_volumes_configMap": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_configMap_name": "my-configmap",
                        "io_k8s_api_core_v1_Pod_spec_volumes_configMap_items": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_volumes_configMap_items_key": "my-config.json",
                                "io_k8s_api_core_v1_Pod_spec_volumes_configMap_items_path": "my-config.json"
                            }
                        ]
                    }
                }
            ]
        }
    }
}