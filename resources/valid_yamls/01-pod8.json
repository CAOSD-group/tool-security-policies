{
    "filename": "01-pod8.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "web",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "play"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "meetupsul.azurecr.io/web:novalidate",
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "web",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_name": "http",
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol": {
                                "io_k8s_api_core_v1_Pod_spec_containers_ports_protocol_TCP": true
                            }
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_requests": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "cpu:256m"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "memory:128Mi"
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:500m"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:256Mi"
                            }
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet": {
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_path": "/health",
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_port": {
                                "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_port_asInteger": 80
                            }
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_initialDelaySeconds": 5,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_timeoutSeconds": 1,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_periodSeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_failureThreshold": 3
                    }
                }
            ]
        }
    }
