{
    "filename": "02-pod-limitado.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_creationTimestamp": {
                "io_k8s_api_core_v1_Pod_metadata_creationTimestamp_isNull": true
            },
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "run",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "giropops"
                }
            ],
            "io_k8s_api_core_v1_Pod_metadata_name": "giropops"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "ubuntu",
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "ubuntu",
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "sleep"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "1800"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:0.5"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:128Mi"
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_requests": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "cpu:0.3"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "memory:64Mi"
                            }
                        ]
                    }
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_dnsPolicy": {
                "io_k8s_api_core_v1_Pod_spec_dnsPolicy_ClusterFirst": true
            },
            "io_k8s_api_core_v1_Pod_spec_restartPolicy": {
                "io_k8s_api_core_v1_Pod_spec_restartPolicy_Always": true
            }
        },
        "io_k8s_api_core_v1_Pod_status": {}
    }
}