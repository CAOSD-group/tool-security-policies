{
    "filename": "cuda12_sample_dcgm-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "dcgmproftester12"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_restartPolicy": {
                "io_k8s_api_core_v1_Pod_spec_restartPolicy_OnFailure": true
            },
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "dcgmproftester12",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nvcr.io/nvidia/cloud-native/dcgm:3.3.0-1-ubuntu22.04",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "/usr/bin/dcgmproftester12"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--no-dcgm-validation"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "-t 1004"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "-d 30"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            "nvidia.com/gpu"
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext": {
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities": {
                            "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities_add": [
                                {
                                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities_add_StringValue": "SYS_ADMIN"
                                }
                            ]
                        }
                    }
                }
            ]
        }
    }
}