{
    "filename": "disk-access-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "disk-access-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_nodeSelector": [
                {
                    "io_k8s_api_core_v1_Pod_spec_nodeSelector_StringValueAdditional": "kubernetes.io/hostname:stanton-03"
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "main-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "alpine:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "/bin/sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "sleep 3600"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext": {
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_privileged": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "host-dev",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/dev"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "host-dev",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/dev",
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_type": "Directory"
                    }
                }
            ]
        }
    }
}