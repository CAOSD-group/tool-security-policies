{
    "filename": "liveness-pod-definition.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "simple-webapp",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "name",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "simple-webapp"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "simple-webapp",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "simple-webapp",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 8080
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet": {
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_path": "/api/ready",
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_port": {
                                "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_port_asInteger": 8080
                            }
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_initialDelaySeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_periodSeconds": 5,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_failureThreshold": 8
                    }
                }
            ]
        }
    }
}