{
    "filename": "data-stored-in-pod.yaml",
    "apiVersion": "apps_v1",
    "config": {
        "io_k8s_api_apps_v1_Deployment_apiVersion": "apps/v1",
        "io_k8s_api_apps_v1_Deployment_kind": "Deployment",
        "io_k8s_api_apps_v1_Deployment_metadata": {
            "io_k8s_api_apps_v1_Deployment_metadata_labels": [
                {
                    "io_k8s_api_apps_v1_Deployment_metadata_labels_KeyMap": "app",
                    "io_k8s_api_apps_v1_Deployment_metadata_labels_ValueMap": "database"
                }
            ],
            "io_k8s_api_apps_v1_Deployment_metadata_name": "database"
        },
        "io_k8s_api_apps_v1_Deployment_spec": {
            "io_k8s_api_apps_v1_Deployment_spec_replicas": 1,
            "io_k8s_api_apps_v1_Deployment_spec_selector": {
                "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels": [
                    {
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_KeyMap": "app",
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_ValueMap": "database"
                    }
                ]
            },
            "io_k8s_api_apps_v1_Deployment_spec_template": {
                "io_k8s_api_apps_v1_Deployment_spec_template_metadata": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_KeyMap": "app",
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_ValueMap": "database"
                        }
                    ]
                },
                "io_k8s_api_apps_v1_Deployment_spec_template_spec": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_image": "mongo",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_name": "mongotest",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_name": "MONGO_INITDB_ROOT_USERNAME",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_value": "admin"
                                },
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_name": "MONGO_INITDB_ROOT_PASSWORD",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_value": "testtesttest"
                                }
                            ],
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts_mountPath": "/data/db",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts_name": "db-store"
                                }
                            ]
                        }
                    ],
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes_name": "db-store",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes_emptyDir": {
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes_emptyDir_isEmpty": true
                            }
                        }
                    ]
                }
            }
        }
    }
}