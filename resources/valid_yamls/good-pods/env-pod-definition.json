{
    "filename": "env-pod-definition.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "simple-webapp-color"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "simple-webapp-color",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "simple-webapp-color",
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:128Mi"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:500m"
                            }
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 8080
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "APP_COLOR",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "pink"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "APP_config",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_key": "configMap"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "APP_secret",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_key": "APP_secret"
                                }
                            }
                        }
                    ]
                }
            ]
        }
    }
}