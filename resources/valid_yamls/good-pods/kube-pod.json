{
    "filename": "kube-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "podu",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "podu"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "kubeki-app",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "kdocku/fareye_kube:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 3000
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_imagePullSecrets": [
                {
                    "io_k8s_api_core_v1_Pod_spec_imagePullSecrets_name": "my-registry-secret"
                }
            ]
        }
    }
}