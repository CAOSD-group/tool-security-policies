{
    "filename": "hostpath-pod1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "hostpath-pod",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "name",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "hostpath-pod"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "hostpath-pod",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/test-nginx",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "myhostpath"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:128Mi"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:500m"
                            }
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "myhostpath",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/tmp/nginx",
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_type": "DirectoryOrCreate"
                    }
                }
            ]
        }
    }
}