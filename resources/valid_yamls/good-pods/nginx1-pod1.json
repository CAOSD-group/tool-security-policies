{
    "filename": "nginx1-pod1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "nginx1",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "nginx"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "author",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "leonardo"
                },
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "env",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "homolog"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx:1.24.0",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_exec": [
                            "cat",
                            "/tmp/health.txt"
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_path": "/",
                                "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_port": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_port_asInteger": 80
                                }
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_periodSeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_initialDelaySeconds": 30
                    }
                }
            ]
        }
    }
}