{
    "filename": "clarus-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "clarus-pod",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "clarus-web"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "clarus-pv-storage",
                    "io_k8s_api_core_v1_Pod_spec_volumes_persistentVolumeClaim": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_persistentVolumeClaim_claimName": "clarus-pv-claim"
                    }
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "mysql:5.7",
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "msql-db",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MYSQL_ROOT_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "R1234r"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MYSQL_DATABASE",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "phonebook"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MYSQL_USER",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "clarus"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MYSQL_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "Clarusway_1"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 3306
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/lib/mysql",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "clarus-pv-storage"
                        }
                    ]
                }
            ]
        }
    }
}