{
    "filename": "frontend-pod-definition.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "myapp-frontend-pod",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "dev",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "frontend-react"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "frontend-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "dwivediavneesh386/frontend:1.1.0",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_envFrom": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_envFrom_configMapRef": {
                                "io_k8s_api_core_v1_Pod_spec_containers_envFrom_configMapRef_name": "myapp-configmap"
                            }
                        }
                    ]
                }
            ]
        }
    }
}