{
    "filename": "ehrbase-metrics-pod.yaml",
    "apiVersion": "apps_v1",
    "config": {
        "io_k8s_api_apps_v1_Deployment_apiVersion": "apps/v1",
        "io_k8s_api_apps_v1_Deployment_kind": "Deployment",
        "io_k8s_api_apps_v1_Deployment_metadata": {
            "io_k8s_api_apps_v1_Deployment_metadata_creationTimestamp": {
                "io_k8s_api_apps_v1_Deployment_metadata_creationTimestamp_isNull": true
            },
            "io_k8s_api_apps_v1_Deployment_metadata_labels": [
                {
                    "io_k8s_api_apps_v1_Deployment_metadata_labels_KeyMap": "app",
                    "io_k8s_api_apps_v1_Deployment_metadata_labels_ValueMap": "ehrbase-metrics"
                }
            ],
            "io_k8s_api_apps_v1_Deployment_metadata_name": "ehrbase-metrics"
        },
        "io_k8s_api_apps_v1_Deployment_spec": {
            "io_k8s_api_apps_v1_Deployment_spec_replicas": 1,
            "io_k8s_api_apps_v1_Deployment_spec_selector": {
                "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels": [
                    {
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_KeyMap": "app",
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_ValueMap": "ehrbase-metrics"
                    }
                ]
            },
            "io_k8s_api_apps_v1_Deployment_spec_strategy": {},
            "io_k8s_api_apps_v1_Deployment_spec_template": {
                "io_k8s_api_apps_v1_Deployment_spec_template_metadata": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_metadata_creationTimestamp": {
                        "io_k8s_api_apps_v1_Deployment_spec_template_metadata_creationTimestamp_isNull": true
                    },
                    "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_KeyMap": "app",
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_ValueMap": "ehrbase-metrics"
                        }
                    ]
                },
                "io_k8s_api_apps_v1_Deployment_spec_template_spec": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_image": "debian",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_name": "debian",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_name": "USER",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_valueFrom": {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_valueFrom_secretKeyRef": {
                                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_valueFrom_secretKeyRef_key": "username",
                                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_valueFrom_secretKeyRef_name": "ehrbase-ehrbase-security-admin-user-secret"
                                        }
                                    }
                                },
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_name": "PASSWD",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_valueFrom": {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_valueFrom_secretKeyRef": {
                                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_valueFrom_secretKeyRef_key": "password",
                                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_valueFrom_secretKeyRef_name": "ehrbase-ehrbase-security-admin-user-secret"
                                        }
                                    }
                                }
                            ],
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_command": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_command_StringValue": "sh"
                                },
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_command_StringValue": "-c"
                                },
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_command_StringValue": "apt-get update && apt-get install -y curl jq\nwhile true; \ndo \n  echo $(date);\n  \n  total_patients=$(curl -s -u \"$USER:$PASSWD\" \"Accept: application/json\"  'http://develop-ehrbase-service:8080/ehrbase/rest/openehr/v1/query/aql?q=SELECT%20COUNT%28e%2Fehr_id%2Fvalue%29%20AS%20total_patients%20FROM%20EHR%20e' | jq '.rows[0][0]')\n  \n  echo query status = $?\n  echo total_patients = $total_patients\n\n  echo total_patients $total_patients | curl -s --data-binary @- http://develop-prometheus-pushgateway:9091/metrics/job/ehrbase-metrics/instance/develop\n  \n  echo push status = $?\n\n  sleep 60; \ndone;\n"
                                }
                            ]
                        }
                    ]
                }
            }
        }
    }
}