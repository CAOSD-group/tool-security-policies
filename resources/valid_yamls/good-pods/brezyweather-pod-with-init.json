{
    "filename": "brezyweather-pod-with-init.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "brezyweather-pod-init"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "codewithpraveen/labs-k8s-brezyweather:1.0",
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "brezyweather-pod",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:100m"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:128Mi"
                            }
                        ]
                    }
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_initContainers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_initContainers_name": "init-sleep",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_image": "busybox:1.36",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "sleep 10"
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_initContainers_name": "init-setup-service",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_image": "busybox:1.36",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "until nslookup brezyweather.staging.svc.cluster.local; do echo waiting for brezyweather service; sleep 1; done"
                        }
                    ]
                }
            ]
        }
    }
}