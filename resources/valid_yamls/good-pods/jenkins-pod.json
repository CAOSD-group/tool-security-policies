{
    "filename": "jenkins-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "maven",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "maven:3.8.3-jdk-11-slim",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "sleep"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "99d"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_Always": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_tty": true
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "hadolint",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "hadolint/hadolint:latest-debian",
                    "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_Always": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "cat"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_tty": true
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "docker",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "docker:20.10.12",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "sleep"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "99d"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "DOCKER_HOST",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "tcp://localhost:2375"
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "docker-daemon",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "docker:20.10.12-dind",
                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext": {
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_privileged": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "DOCKER_TLS_CERTDIR",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": ""
                        }
                    ]
                }
            ]
        }
    }
}