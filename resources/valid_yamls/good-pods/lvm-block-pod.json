{
    "filename": "lvm-block-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "carina-block-pod",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "carina"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "centos",
                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext": {
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities": {
                            "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities_add": [
                                {
                                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities_add_StringValue": "SYS_RAWIO"
                                }
                            ]
                        }
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "centos:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_IfNotPresent": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "/bin/sleep"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "infinity"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeDevices": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeDevices_name": "data",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeDevices_devicePath": "/dev/xvda"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "data",
                    "io_k8s_api_core_v1_Pod_spec_volumes_persistentVolumeClaim": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_persistentVolumeClaim_claimName": "lvm-block-pvc"
                    }
                }
            ]
        }
    }
}