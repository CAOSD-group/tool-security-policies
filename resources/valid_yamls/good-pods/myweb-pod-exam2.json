{
    "filename": "myweb-pod-exam2.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "myweb",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "prodns"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "myweb-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx:1.14",
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_requests": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "cpu:200m"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "memory:500Mi"
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:1"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:1Gi"
                            }
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "DB",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "mydb"
                        }
                    ]
                }
            ]
        }
    }
}