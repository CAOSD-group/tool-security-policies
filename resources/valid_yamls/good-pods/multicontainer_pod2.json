{
    "filename": "multicontainer_pod2.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "webapp-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_dnsPolicy": {
                "io_k8s_api_core_v1_Pod_spec_dnsPolicy_None": true
            },
            "io_k8s_api_core_v1_Pod_spec_dnsConfig": {
                "io_k8s_api_core_v1_Pod_spec_dnsConfig_nameservers": [
                    {
                        "io_k8s_api_core_v1_Pod_spec_dnsConfig_nameservers_StringValue": "8.8.8.8"
                    },
                    {
                        "io_k8s_api_core_v1_Pod_spec_dnsConfig_nameservers_StringValue": "8.8.4.4"
                    }
                ]
            },
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "webapp-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "shared-data",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/usr/share/nginx/html"
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "fetcher-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "busybox:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "/bin/sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "-c"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "mkdir -p /shared-data\nwhile true; do\n  echo \"Fetching webpage...\"\n  wget -O /shared-data/index.html https://raw.githubusercontent.com/mdn/beginner-html-site/gh-pages/index.html || echo \"Failed to fetch\"\n  echo \"Listing contents of /shared-data:\"\n  ls -l /shared-data\n  sleep 3600\ndone\n"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "shared-data",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/shared-data"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "shared-data",
                    "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir_isEmpty": true
                    }
                }
            ]
        }
    }
}