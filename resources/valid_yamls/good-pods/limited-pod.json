{
    "filename": "limited-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "limited-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "busybox",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "dd"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "if=/dev/zero"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "of=/dev/null"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "main",
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:20Mi"
                            }
                        ]
                    }
                }
            ]
        }
    }
}