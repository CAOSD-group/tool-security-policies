{
    "filename": "mysecret-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "secret-env-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "mycontainer",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "redis",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "SECRET_USERNAME",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_name": "mysecret",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_key": "username"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "SECRET_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_name": "mysecret",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_secretKeyRef_key": "password"
                                }
                            }
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_restartPolicy": {
                "io_k8s_api_core_v1_Pod_spec_restartPolicy_Never": true
            }
        }
    }
}