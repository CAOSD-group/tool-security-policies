{
    "filename": "httpd-pod1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "httpd-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "httpd-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "httpd:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_requests": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "memory:15Mi"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "cpu:100m"
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:20Mi"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:100m"
                            }
                        ]
                    }
                }
