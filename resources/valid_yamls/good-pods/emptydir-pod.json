{
    "filename": "emptydir-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "pod-ed",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "notes"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "shekeriev/k8s-notes",
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "container-ed",
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/data",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "data-volume"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "data-volume",
                    "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir_isEmpty": true
                    }
                }
            ]
        }
    }
}