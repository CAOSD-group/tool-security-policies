{
    "filename": "Multi-Container-Pods2.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "flask-pg-multi-container",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "flaskapp"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "flask-app",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "dockeronur/flaskapp-pg:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 8000
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "postgres",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "postgres:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 5432
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "POSTGRES_DB",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "dbapp"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "POSTGRES_USER",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "postgres"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "POSTGRES_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "passwd"
                        }
                    ]
                }
            ]
        }
    }
}