            "io_k8s_api_apps_v1_Deployment_metadata_name": "nginx-nfs",
            "io_k8s_api_apps_v1_Deployment_metadata_namespace": "default"
        },
        "io_k8s_api_apps_v1_Deployment_spec": {
            "io_k8s_api_apps_v1_Deployment_spec_replicas": 1,
