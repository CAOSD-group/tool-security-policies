        "io_k8s_api_apps_v1_Deployment_kind": "Deployment",
        "io_k8s_api_apps_v1_Deployment_metadata": {
            "io_k8s_api_apps_v1_Deployment_metadata_annotations": [
                {
                    "io_k8s_api_apps_v1_Deployment_metadata_annotations_KeyMap": "deployment.kubernetes.io/revision",
                    "io_k8s_api_apps_v1_Deployment_metadata_annotations_ValueMap": "1"
                }
            ],
            "io_k8s_api_apps_v1_Deployment_metadata_generation": 1,
            "io_k8s_api_apps_v1_Deployment_metadata_labels": [
                {
                    "io_k8s_api_apps_v1_Deployment_metadata_labels_KeyMap": "run",
                    "io_k8s_api_apps_v1_Deployment_metadata_labels_ValueMap": "nginx"
