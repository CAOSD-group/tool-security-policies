                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts_name": "nfs-vol",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts_mountPath": "/opt"
