{
    "filename": "env-pod2.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "env-pod",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "purpose",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "demonstrate-envars"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "envar-demo-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "gcr.io/google-samples/node-hello:1.0",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "DEMO-GREETING",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "Hello from the enviroment"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "DEMO-FAREWELL",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "Such a sweet sorrow"
                        }
                    ]
                }
            ]
        }
    }
}