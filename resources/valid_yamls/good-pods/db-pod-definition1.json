{
    "filename": "db-pod-definition1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "db-server",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "db",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "name",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "db-server"
