{
    "filename": "k8stools-pod1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "k8stools",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "default",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "k8stools"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_serviceAccountName": "vault-auth",
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "k8stools",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "wbitt/network-multitool:alpine-extra",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "VAULT_ADDR",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "http://192.168.65.2:8200"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "KUBE_TOKEN",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)"
                        }
                    ]
                }
            ]
        }
    }
}