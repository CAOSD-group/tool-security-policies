{
    "filename": "cka-q5-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "multi-app",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "test"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_initContainers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_initContainers_name": "init-busybox",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_image": "busybox",
                    "io_k8s_api_core_v1_Pod_spec_initContainers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_args_StringValue": "sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_args_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_args_StringValue": "date > /app/data/date"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_initContainers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_volumeMounts_name": "cka-volume",
                            "io_k8s_api_core_v1_Pod_spec_initContainers_volumeMounts_mountPath": "/app/data"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx:alpine",
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "sh"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "cat /app/data/date && sleep 6000"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "cka-volume",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/app/data"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "cka-volume",
                    "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir_isEmpty": true
                    }
                }
            ]
        }
    }
}