{
    "filename": "db-pod-definition.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "myapp-db-pod",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "dev",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "database"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "database-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "dwivediavneesh386/database:1.0.0",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "MYSQL_ROOT_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "root"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "DB_NAME",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "myapp"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 3306
                        }
                    ]
                }
            ]
        }
    }
}