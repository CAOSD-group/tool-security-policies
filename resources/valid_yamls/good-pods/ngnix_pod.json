                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_requests_asString": "cpu:900m"
                            }
                        ],
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:1Gi"
