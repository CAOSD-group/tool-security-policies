{
    "filename": "my-pod-invoke.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "my-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "my-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "my-image",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "DATABASE_URL",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "jdbc:mysql://my-service/mydb"
                        }
                    ]
                }
            ]
        }
    }
}