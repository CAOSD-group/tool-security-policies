                            ],
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts_name": "pvc-blob",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts_mountPath": "/usr/share/nginx/html"
                                }
                            ]
                        }
                    ],
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes_name": "pvc-blob",
