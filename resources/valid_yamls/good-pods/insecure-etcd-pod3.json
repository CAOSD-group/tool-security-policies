{
    "filename": "insecure-etcd-pod3.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "kube-aggregator",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "kube-public"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_hostNetwork": true,
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "kube-aggregator",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "kube-aggregator",
                    "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_IfNotPresent": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "/usr/local/bin/kube-aggregator"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--secure-port=9443"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--kubeconfig=/var/run/auth-client/kube-aggregator.kubeconfig"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--authentication-kubeconfig=/var/run/auth-client/kube-aggregator.kubeconfig"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--authorization-kubeconfig=/var/run/auth-client/kube-aggregator.kubeconfig"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--proxy-client-cert-file=/var/run/auth-proxy-client/client-auth-proxy.crt"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--proxy-client-key-file=/var/run/auth-proxy-client/client-auth-proxy.key"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--tls-cert-file=/var/run/serving-cert/serving-kube-aggregator.crt"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--tls-private-key-file=/var/run/serving-cert/serving-kube-aggregator.key"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--client-ca-file=/var/run/client-ca/client-ca.crt"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--requestheader-username-headers=X-Remote-User"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--requestheader-group-headers=X-Remote-Group"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--requestheader-extra-headers-prefix=X-Remote-Extra-"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--requestheader-client-ca-file=/var/run/request-header-ca/request-header-ca.crt"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "--etcd-servers=http://127.0.0.1:2379"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 9443,
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_hostPort": 9443
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/run/request-header-ca",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "volume-request-header-ca",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/run/client-ca",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "volume-client-ca",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/run/auth-proxy-client",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "volume-auth-proxy-client",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/run/etcd-client-cert",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "volume-etcd-client-cert",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/run/serving-ca",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "volume-serving-ca",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/run/serving-cert",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "volume-serving-cert",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/run/etcd-ca",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "volume-etcd-ca",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/run/auth-client",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "volume-auth-client",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "volume-request-header-ca",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/run/kubernetes/"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "volume-client-ca",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/run/kubernetes/"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "volume-auth-proxy-client",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/run/kubernetes/"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "volume-etcd-client-cert",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/run/kubernetes/"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "volume-serving-cert",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/run/kubernetes/"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "volume-serving-ca",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/run/kubernetes/"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "volume-etcd-ca",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/run/kubernetes/"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "volume-auth-client",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/run/kubernetes/"
                    }
                }
            ]
        }
    }
}