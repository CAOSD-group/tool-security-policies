{
    "filename": "multi-container-pod12.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "my-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_terminationGracePeriodSeconds": 1,
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx"
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx-helper",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "vinsdocker/util",
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "sleep"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "3600"
                        }
                    ]
                }
            ]
        }
    }
}