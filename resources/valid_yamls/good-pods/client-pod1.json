                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "bitnami/postgresql:11.12.0-debian-10-r13",
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "postgresql",
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "ALLOW_EMPTY_PASSWORD",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_value": "yes"
