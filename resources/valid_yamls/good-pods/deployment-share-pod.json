{
    "filename": "deployment-share-pod.yaml",
    "apiVersion": "apps_v1",
    "config": {
        "io_k8s_api_apps_v1_Deployment_apiVersion": "apps/v1",
        "io_k8s_api_apps_v1_Deployment_kind": "Deployment",
        "io_k8s_api_apps_v1_Deployment_metadata": {
            "io_k8s_api_apps_v1_Deployment_metadata_name": "share-pod-deployment",
            "io_k8s_api_apps_v1_Deployment_metadata_namespace": "u1"
        },
        "io_k8s_api_apps_v1_Deployment_spec": {
            "io_k8s_api_apps_v1_Deployment_spec_replicas": 1,
            "io_k8s_api_apps_v1_Deployment_spec_selector": {
                "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels": [
                    {
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_KeyMap": "open-ending.com/name",
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_ValueMap": "share-pod-app"
                    }
                ]
            },
            "io_k8s_api_apps_v1_Deployment_spec_template": {
                "io_k8s_api_apps_v1_Deployment_spec_template_metadata": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_KeyMap": "open-ending.com/name",
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_ValueMap": "share-pod-app"
                        }
                    ]
                },
                "io_k8s_api_apps_v1_Deployment_spec_template_spec": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_name": "mss-app-container",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_image": "open-ending.com/mss-app:latest",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_imagePullPolicy": {
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_imagePullPolicy_Never": true
                            },
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_ports": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_ports_containerPort": 8080
                                }
                            ],
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_livenessProbe": {
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_livenessProbe_httpGet": {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_livenessProbe_httpGet_path": "/actuator/health",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_livenessProbe_httpGet_port": {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_livenessProbe_httpGet_port_asInteger": 8080
                                    }
                                }
                            },
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources": {
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_requests": [
                                    {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_requests_asString": "cpu:300m"
                                    },
                                    {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_requests_asString": "memory:256Mi"
                                    }
                                ],
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_limits": [
                                    {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_limits_asString": "cpu:1000m"
                                    },
                                    {
                                        "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_resources_limits_asString": "memory:512Mi"
                                    }
                                ]
                            }
                        },
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_name": "redis-master",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_image": "redis:7.2.4",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_imagePullPolicy": {
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_imagePullPolicy_IfNotPresent": true
                            },
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_ports": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_ports_containerPort": 6739
                                }
                            ]
                        }
                    ],
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_nodeSelector": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_nodeSelector_StringValueAdditional": "workload:fulltime"
                        }
                    ]
                }
            }
        }
    }
}