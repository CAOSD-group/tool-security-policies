{
    "filename": "multi-pod-empty-dir.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "more-pod-vol"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "ngin1",
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/centos",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "demo"
                        }
                    ]
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "alpine:latest",
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "alpine1",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "sleep"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "3600"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/centos",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "demo"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "demo",
                    "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_emptyDir_isEmpty": true
                    }
                }
            ]
        }
    }
