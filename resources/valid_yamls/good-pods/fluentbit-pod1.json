{
    "filename": "fluentbit-pod1.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "fluentbit",
            "io_k8s_api_core_v1_Pod_metadata_namespace": "logging",
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "app",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "fluentbit"
                }
            ]
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_priorityClassName": "system-node-critical",
            "io_k8s_api_core_v1_Pod_spec_serviceAccountName": "fluentbit",
            "io_k8s_api_core_v1_Pod_spec_terminationGracePeriodSeconds": 10,
            "io_k8s_api_core_v1_Pod_spec_securityContext": {
                "io_k8s_api_core_v1_Pod_spec_securityContext_seccompProfile": {
                    "io_k8s_api_core_v1_Pod_spec_securityContext_seccompProfile_type": {
                        "io_k8s_api_core_v1_Pod_spec_securityContext_seccompProfile_type_RuntimeDefault": true
                    }
                }
            },
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "fluent-bit",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "fluent/fluent-bit:1.5",
                    "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy": {
                        "io_k8s_api_core_v1_Pod_spec_containers_imagePullPolicy_Always": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 2020
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "cpu:200m"
                            },
                            {
                                "io_k8s_api_core_v1_Pod_spec_containers_resources_limits_asString": "memory:256Mi"
                            }
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_env": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "Zone",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_name": "log-config",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_key": "Zone"
                                }
                            }
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_env_name": "Region",
                            "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom": {
                                "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef": {
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_name": "log-config",
                                    "io_k8s_api_core_v1_Pod_spec_containers_env_valueFrom_configMapKeyRef_key": "Region"
                                }
                            }
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "varlog",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/log"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "varlibdockercontainers",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/var/lib/docker/containers",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_readOnly": true
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_name": "fluent-bit-config",
                            "io_k8s_api_core_v1_Pod_spec_containers_volumeMounts_mountPath": "/fluent-bit/etc/"
                        }
                    ]
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_volumes": [
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "varlog",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/log"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "varlibdockercontainers",
                    "io_k8s_api_core_v1_Pod_spec_volumes_hostPath": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_hostPath_path": "/var/lib/docker/containers"
                    }
                },
                {
                    "io_k8s_api_core_v1_Pod_spec_volumes_name": "fluent-bit-config",
                    "io_k8s_api_core_v1_Pod_spec_volumes_configMap": {
                        "io_k8s_api_core_v1_Pod_spec_volumes_configMap_name": "fluent-bit-config"
                    }
                }
            ]
        }
    }
}