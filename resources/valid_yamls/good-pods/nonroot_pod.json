{
    "filename": "nonroot_pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "timeserver-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_securityContext": {
                "io_k8s_api_core_v1_Pod_spec_securityContext_seccompProfile": {
                    "io_k8s_api_core_v1_Pod_spec_securityContext_seccompProfile_type": {
                        "io_k8s_api_core_v1_Pod_spec_securityContext_seccompProfile_type_RuntimeDefault": true
                    }
                }
            },
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "timeserver-container",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "docker.io/wdenniss/timeserver:7",
                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext": {
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_runAsNonRoot": true,
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_allowPrivilegeEscalation": false,
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_runAsUser": 1001,
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities": {
                            "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities_drop": [
                                {
                                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext_capabilities_drop_StringValue": "ALL"
                                }
                            ]
                        }
                    }
                }
            ]
        }
    }
}