{
    "filename": "liveness-pod-httpd.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_labels": [
                {
                    "io_k8s_api_core_v1_Pod_metadata_labels_KeyMap": "test",
                    "io_k8s_api_core_v1_Pod_metadata_labels_ValueMap": "liveness"
                }
            ],
            "io_k8s_api_core_v1_Pod_metadata_name": "liveness-http"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "liveness",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "registry.k8s.io/e2e-test-images/agnhost:2.40",
                    "io_k8s_api_core_v1_Pod_spec_containers_args": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_args_StringValue": "liveness"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet": {
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_path": "/healthz",
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_port": {
                                "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_port_asInteger": 8080
                            },
                            "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_httpHeaders": [
                                {
                                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_httpHeaders_name": "Custom-Header",
                                    "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_httpGet_httpHeaders_value": "Awesome"
                                }
                            ]
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_initialDelaySeconds": 3,
                        "io_k8s_api_core_v1_Pod_spec_containers_livenessProbe_periodSeconds": 3
                    }
                }
            ]
        }
    }
}