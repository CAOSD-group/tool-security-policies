{
    "filename": "gpu-diagnostic-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "gpu-diagnostic-pod"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "cuda-toolkit",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nvidia/cuda:12.1.1-base-ubuntu22.04",
                    "io_k8s_api_core_v1_Pod_spec_containers_command": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "sleep"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_command_StringValue": "infinity"
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_resources": {
                        "io_k8s_api_core_v1_Pod_spec_containers_resources_limits": [
                            "nvidia.com/gpu"
                        ]
                    },
                    "io_k8s_api_core_v1_Pod_spec_containers_securityContext": {
                        "io_k8s_api_core_v1_Pod_spec_containers_securityContext_privileged": true
                    }
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_nodeSelector": [
                {
                    "io_k8s_api_core_v1_Pod_spec_nodeSelector_StringValueAdditional": "pool:doodle"
                }
            ],
            "io_k8s_api_core_v1_Pod_spec_tolerations": [
                {
                    "io_k8s_api_core_v1_Pod_spec_tolerations_key": "nvidia.com/gpu",
                    "io_k8s_api_core_v1_Pod_spec_tolerations_operator": {
                        "io_k8s_api_core_v1_Pod_spec_tolerations_operator_Exists": true
                    },
                    "io_k8s_api_core_v1_Pod_spec_tolerations_effect": {
                        "io_k8s_api_core_v1_Pod_spec_tolerations_effect_NoSchedule": true
                    }
                }
            ]
        }
    }
}