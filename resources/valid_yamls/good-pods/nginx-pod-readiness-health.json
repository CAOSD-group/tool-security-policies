{
    "filename": "nginx-pod-readiness-health.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_Pod_apiVersion": "v1",
        "io_k8s_api_core_v1_Pod_kind": "Pod",
        "io_k8s_api_core_v1_Pod_metadata": {
            "io_k8s_api_core_v1_Pod_metadata_name": "nginx"
        },
        "io_k8s_api_core_v1_Pod_spec": {
            "io_k8s_api_core_v1_Pod_spec_containers": [
                {
                    "io_k8s_api_core_v1_Pod_spec_containers_name": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_image": "nginx",
                    "io_k8s_api_core_v1_Pod_spec_containers_ports": [
                        {
                            "io_k8s_api_core_v1_Pod_spec_containers_ports_containerPort": 80
                        }
                    ],
                    "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe": {
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_httpGet": {
                            "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_httpGet_path": "/healthz",
                            "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_httpGet_port": {
                                "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_httpGet_port_asInteger": 80
                            }
                        },
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_initialDelaySeconds": 15,
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_periodSeconds": 10,
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_timeoutSeconds": 5,
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_successThreshold": 1,
                        "io_k8s_api_core_v1_Pod_spec_containers_readinessProbe_failureThreshold": 3
                    }
                }
            ]
        }
    }
}