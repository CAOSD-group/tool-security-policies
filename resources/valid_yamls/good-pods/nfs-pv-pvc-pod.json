{
    "filename": "nfs-pv-pvc-pod.yaml",
    "apiVersion": "v1",
    "config": {
        "io_k8s_api_core_v1_PersistentVolume_apiVersion": "v1",
        "io_k8s_api_core_v1_PersistentVolume_kind": "PersistentVolume",
        "io_k8s_api_core_v1_PersistentVolume_metadata": {
            "io_k8s_api_core_v1_PersistentVolume_metadata_name": "nfs-pv"
        },
        "io_k8s_api_core_v1_PersistentVolume_spec": {
            "io_k8s_api_core_v1_PersistentVolume_spec_capacity": [
                {
                    "io_k8s_api_core_v1_PersistentVolume_spec_capacity_asString": "storage:10Gi"
                }
            ],
            "io_k8s_api_core_v1_PersistentVolume_spec_volumeMode": "Filesystem",
            "io_k8s_api_core_v1_PersistentVolume_spec_accessModes": [
                {
                    "io_k8s_api_core_v1_PersistentVolume_spec_accessModes_StringValue": "ReadWriteMany"
                }
            ],
            "io_k8s_api_core_v1_PersistentVolume_spec_persistentVolumeReclaimPolicy": {
                "io_k8s_api_core_v1_PersistentVolume_spec_persistentVolumeReclaimPolicy_Recycle": true
            },
            "io_k8s_api_core_v1_PersistentVolume_spec_storageClassName": "nfs",
            "io_k8s_api_core_v1_PersistentVolume_spec_mountOptions": [
                {
                    "io_k8s_api_core_v1_PersistentVolume_spec_mountOptions_StringValue": "hard"
                },
                {
                    "io_k8s_api_core_v1_PersistentVolume_spec_mountOptions_StringValue": "nfsvers=4.1"
                }
            ],
            "io_k8s_api_core_v1_PersistentVolume_spec_nfs": {
                "io_k8s_api_core_v1_PersistentVolume_spec_nfs_path": "/nfs-share/kubernetes/html",
                "io_k8s_api_core_v1_PersistentVolume_spec_nfs_server": "192.168.0.96"
            }
        }
    }
}