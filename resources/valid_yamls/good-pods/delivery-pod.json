                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "-c"
                        },
                        {
                            "io_k8s_api_core_v1_Pod_spec_initContainers_command_StringValue": "until nslookup api-gateway-service; do sleep 2; done"
