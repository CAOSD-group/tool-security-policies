{
    "filename": "02-pod-pvc_2.yaml",
    "apiVersion": "apps_v1",
    "config": {
        "io_k8s_api_apps_v1_Deployment_apiVersion": "apps/v1",
        "io_k8s_api_apps_v1_Deployment_kind": "Deployment",
        "io_k8s_api_apps_v1_Deployment_metadata": {
            "io_k8s_api_apps_v1_Deployment_metadata_name": "mysql",
            "io_k8s_api_apps_v1_Deployment_metadata_labels": [
                {
                    "io_k8s_api_apps_v1_Deployment_metadata_labels_KeyMap": "mysql",
                    "io_k8s_api_apps_v1_Deployment_metadata_labels_ValueMap": "ready"
                }
            ]
        },
        "io_k8s_api_apps_v1_Deployment_spec": {
            "io_k8s_api_apps_v1_Deployment_spec_replicas": 1,
            "io_k8s_api_apps_v1_Deployment_spec_selector": {
                "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels": [
                    {
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_KeyMap": "mysql",
                        "io_k8s_api_apps_v1_Deployment_spec_selector_matchLabels_ValueMap": "ready"
                    }
                ]
            },
            "io_k8s_api_apps_v1_Deployment_spec_template": {
                "io_k8s_api_apps_v1_Deployment_spec_template_metadata": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_KeyMap": "mysql",
                            "io_k8s_api_apps_v1_Deployment_spec_template_metadata_labels_ValueMap": "ready"
                        }
                    ]
                },
                "io_k8s_api_apps_v1_Deployment_spec_template_spec": {
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_name": "mysql",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_image": "mysql:5.7",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_name": "MYSQL_ROOT_PASSWORD",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_env_value": "12345678"
                                }
                            ],
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts": [
                                {
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts_mountPath": "/var/lib/mysql",
                                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_containers_volumeMounts_name": "vol-mysql"
                                }
                            ]
                        }
                    ],
                    "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes": [
                        {
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes_name": "vol-mysql",
                            "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes_persistentVolumeClaim": {
                                "io_k8s_api_apps_v1_Deployment_spec_template_spec_volumes_persistentVolumeClaim_claimName": "test-pvc"
                            }
                        }
                    ]
                }
            }
        }
    }
}